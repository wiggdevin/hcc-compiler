# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Demo persona fixtures live at web/public/{sp2,intakes}/ — committed to git
# because Vercel rootDirectory=web/ can't reach ../docs/ at build time.
# Run `pnpm prebuild` after editing docs/examples/sp2/ or tests/fixtures/intakes/
# to refresh the bundled copies.
