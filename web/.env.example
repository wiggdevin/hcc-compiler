# =============================================================================
# hcc-compiler web — required production env vars
# Copy this file to .env.local for dev. Set these on Vercel for production.
# =============================================================================

# --- Supabase --------------------------------------------------------------
# Project URL + anon key are PUBLIC (shipped to browser). Service role key is
# server-only and bypasses RLS — never expose to client code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email) ------------------------------------------
RESEND_API_KEY=
# Either bare "noreply@yourdomain.com" or full "Name <noreply@yourdomain.com>".
# The library wraps a bare address with "HCC Compiler <addr>". The sender
# domain MUST be verified at https://resend.com/domains.
RESEND_FROM="HCC Compiler <noreply@yourdomain.com>"

# --- LLM (schedule generator) — Anthropic-compatible endpoint --------------
# Schedule rendering calls an Anthropic-compatible /v1/messages endpoint.
# In production this is the Claude Max proxy at zsa-tutor.zerosumsolutions.com;
# locally point at the dev proxy.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=http://localhost:11455
SCHEDULE_MODEL=claude-sonnet-4-6

# --- Compiler-API (Fly sidecar) --------------------------------------------
# The Vercel /api/intakes/[id]/compile route forwards to the Fly service with
# this token in Authorization: Bearer <token>. The exact same value must be
# set as a Fly secret on the compiler-api app.
COMPILER_API_URL=https://hcc-compiler-api.fly.dev
COMPILER_API_TOKEN=

# --- Stripe (billing) ------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ACTIVE_COACH=
STRIPE_PRICE_SINGLE_PLAN_CREDIT=

# --- App routing -----------------------------------------------------------
# Canonical public URL for the web app. Used to build share links inside
# emails ("Your plan is ready at {NEXT_PUBLIC_APP_URL}/p/{token}").
NEXT_PUBLIC_APP_URL=https://hcc-compiler-web.vercel.app
NEXT_PUBLIC_SITE_URL=

# --- Optional ---------------------------------------------------------------
# PDF export. SPARTICUZ_CHROMIUM_PATH overrides the bundled @sparticuz/chromium
# binary in local dev; CHROMIUM_PATH is a more generic fallback. Production
# uses the bundled binary, no env needed.
SPARTICUZ_CHROMIUM_PATH=
CHROMIUM_PATH=

# Internal cron / webhook calls. /api/email/welcome rejects requests whose
# Authorization header doesn't match this secret.
INTERNAL_API_SECRET=
